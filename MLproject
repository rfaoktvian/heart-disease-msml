name: heart-disease-msml

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators:
        type: int
        default: 200
      max_depth:
        type: int
        default: 15
      min_samples_split:
        type: int
        default: 5
      test_size:
        type: float
        default: 0.2
      contamination:
        type: float
        default: 0.05
    command: "python train.py --n_estimators {n_estimators} --max_depth {max_depth} --min_samples_split {min_samples_split} --test_size {test_size} --contamination {contamination}"
